APP_NAME=InferHub
APP_ENV=local
LOG_LEVEL=INFO
API_VERSION=v1
API_KEY_PEPPER=change-me-in-local-dev
DEFAULT_FREE_RPM=30
DEFAULT_ENTERPRISE_RPM=600
DEFAULT_ADMIN_RPM=1200
REQUEST_BODY_LIMIT_BYTES=10485760

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inferhub
POSTGRES_USER=inferhub
POSTGRES_PASSWORD=inferhub

REDIS_URL=redis://redis:6379/0

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=inferhub
CLICKHOUSE_USER=inferhub
CLICKHOUSE_PASSWORD=inferhub

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30

FLOCI_ENDPOINT_URL=http://floci:4566
FLOCI_REGION=us-east-1
FLOCI_ACCESS_KEY_ID=inferhub
FLOCI_SECRET_ACCESS_KEY=inferhub-local
S3_BUCKET_MODEL_ARTIFACTS=inferhub-model-artifacts
